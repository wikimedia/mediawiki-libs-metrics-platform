{
	"opts": {
		"destination": "docs",
		"pedantic": true,
		"recurse": true,
		"template": "node_modules/jsdoc-wmf-theme"
	},
	"plugins": [
		"plugins/markdown",
		"plugins/summarize"
	],
	"source": {
		"include": [ "src" ]
	},
	"sourceType": "module",
	"templates": {
		"cleverLinks": true,
		"default": {
			"useLongnameInNav": true
		},
		"wmf": {
			"repository": "https://gitlab.wikimedia.org/repos/data-engineering/metrics-platform/"
		}
	}
}
